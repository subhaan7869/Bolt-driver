{
  "entities": {
    "driver_profile": {
      "title": "Driver Profile",
      "description": "The stats, settings, insurance, and face verification details of a Swift driver.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The unique user authenticated registration identifier." },
        "taxiStats": {
          "type": "object",
          "description": "Driver dispatch taxi statistics object.",
          "properties": {
            "rating": { "type": "number" },
            "acceptanceRate": { "type": "number" },
            "cancellationRate": { "type": "number" },
            "todayEarnings": { "type": "number" },
            "weeklyEarnings": { "type": "number" },
            "hoursOnline": { "type": "number" },
            "completedTripsCount": { "type": "number" },
            "balance": { "type": "number" }
          }
        },
        "foodStats": {
          "type": "object",
          "description": "Driver dispatch food delivery statistics object.",
          "properties": {
            "rating": { "type": "number" },
            "acceptanceRate": { "type": "number" },
            "cancellationRate": { "type": "number" },
            "todayEarnings": { "type": "number" },
            "weeklyEarnings": { "type": "number" },
            "hoursOnline": { "type": "number" },
            "completedTripsCount": { "type": "number" },
            "balance": { "type": "number" }
          }
        },
        "insuranceVerified": { "type": "boolean", "description": "Indicates whether driver has comprehensive transport and hire insurance verified." },
        "insurancePolicyNo": { "type": "string", "description": "UK standard Hire & Reward carriage Policy number." },
        "insuranceExpiry": { "type": "string", "description": "Expiry calendar date parameters." },
        "faceVerified": { "type": "boolean", "description": "Verification status of physical biometric face selfie checks." },
        "faceSelfieSnapshot": { "type": "string", "description": "Base64 localized vector thumbnail representation." },
        "faceVerificationTime": { "type": "string", "description": "Physical instant validation timestamp." },
        "updatedAt": { "type": "string", "description": "Server synchronization record check timestamp." }
      },
      "required": ["userId", "insuranceVerified", "insurancePolicyNo", "insuranceExpiry", "faceVerified", "taxiStats", "foodStats"]
    },
    "completed_trip": {
      "title": "Completed Trip Record",
      "description": "Historical register archive of a completed carriage or delivery order.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "passengerName": { "type": "string" },
        "pickupAddress": { "type": "string" },
        "dropoffAddress": { "type": "string" },
        "fare": { "type": "number" },
        "tip": { "type": "number" },
        "timestamp": { "type": "string" },
        "ratingValue": { "type": "number" },
        "surgeMultiplier": { "type": "number" }
      },
      "required": ["id", "passengerName", "pickupAddress", "dropoffAddress", "fare", "tip", "timestamp", "ratingValue", "surgeMultiplier"]
    },
    "log_event": {
      "title": "Simulator Log Event",
      "description": "Chronological session event trail details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string" },
        "type": { "type": "string" },
        "message": { "type": "string" }
      },
      "required": ["id", "timestamp", "type", "message"]
    },
    "verification_code": {
      "title": "Verification Code OTP",
      "description": "Short-lived verification codes generated for daily secure driver compliance.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "description": "The email address requesting the verification code." },
        "code": { "type": "string", "description": "The active 6-digit OTP code." },
        "expiresAt": { "type": "string", "description": "The expiration ISO timestamp." },
        "verified": { "type": "boolean", "description": "Whether the OTP was successfully validated." }
      },
      "required": ["email", "code", "expiresAt", "verified"]
    }
  },
  "firestore": {
    "drivers/{userId}": {
      "schema": "driver_profile",
      "description": "Primary document representing driver info and real-time saved statistics."
    },
    "drivers/{userId}/completedTrips/{tripId}": {
      "schema": "completed_trip",
      "description": "Historically archived list of complete orders."
    },
    "drivers/{userId}/logs/{logId}": {
      "schema": "log_event",
      "description": "Simulated dispatcher tracking logs."
    },
    "verification_codes/{emailId}": {
      "schema": "verification_code",
      "description": "Short-lived OTP codes to secure driver logins and compliance."
    }
  }
}
