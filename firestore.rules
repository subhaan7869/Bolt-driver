rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (default deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Global authorization helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    // Entity shape validation helpers
    function isValidDriverStats(stats) {
      return stats.rating is number
        && stats.acceptanceRate is number
        && stats.cancellationRate is number
        && stats.todayEarnings is number
        && stats.weeklyEarnings is number
        && stats.hoursOnline is number
        && stats.completedTripsCount is number
        && stats.balance is number;
    }

    function isValidDriverProfile(data, userId) {
      return data.userId == userId
        && data.insuranceVerified is bool
        && data.insurancePolicyNo is string
        && data.insuranceExpiry is string
        && data.faceVerified is bool
        && data.faceSelfieSnapshot is string
        && data.updatedAt is string
        && isValidDriverStats(data.taxiStats)
        && isValidDriverStats(data.foodStats);
    }

    function isValidCompletedTrip(data) {
      return data.id is string
        && data.passengerName is string
        && data.pickupAddress is string
        && data.dropoffAddress is string
        && data.fare is number
        && data.tip is number
        && data.timestamp is string
        && data.ratingValue is number
        && data.surgeMultiplier is number;
    }

    function isValidLogEvent(data) {
      return data.id is string
        && data.timestamp is string
        && data.type is string
        && data.message is string;
    }

    function isValidVerificationCode(data) {
      return data.email is string
        && data.code is string
        && data.expiresAt is string
        && data.verified is bool;
    }

    // Drivers root collection rules
    match /drivers/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidDriverProfile(incoming(), userId);
      allow update: if isOwner(userId) && isValidDriverProfile(incoming(), userId);
      allow delete: if isOwner(userId);

      // Subcollection for completed rides/deliveries
      match /completedTrips/{tripId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidCompletedTrip(incoming());
        allow delete: if isOwner(userId);
      }

      // Subcollection for simulator activity audit trails
      match /logs/{logId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidLogEvent(incoming());
        allow delete: if isOwner(userId);
      }
    }

    // Verification codes collection rules
    match /verification_codes/{emailId} {
      allow get, delete: if true;
      allow create, update: if isValidVerificationCode(incoming());
    }
  }
}
